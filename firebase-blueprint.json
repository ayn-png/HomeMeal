{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "provider"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "meals": {
      "title": "Meal",
      "description": "Information about a home-cooked meal",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["veg", "non-veg"] },
        "imageUrl": { "type": "string" },
        "providerId": { "type": "string" },
        "providerName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "price", "category", "imageUrl", "providerId", "providerName", "createdAt"]
    },
    "orders": {
      "title": "Order",
      "description": "Order records for meals",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "mealId": { "type": "string" },
        "mealTitle": { "type": "string" },
        "mealPrice": { "type": "number" },
        "mealImageUrl": { "type": "string" },
        "providerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "delivered"] },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "userName", "mealId", "mealTitle", "mealPrice", "mealImageUrl", "providerId", "status", "timestamp"]
    },
    "reviews": {
      "title": "Review",
      "description": "Rating and feedback for a meal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "mealId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "userName", "mealId", "rating", "comment", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "User profiles indexed by UID"
    },
    "/meals/{mealId}": {
      "schema": "meals",
      "description": "Collection of all available meals"
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "All orders in the system"
    },
    "/reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Reviews linked to meals"
    }
  }
}
