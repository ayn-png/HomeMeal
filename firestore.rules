rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    // Validation Blueprints (Pillar 2)
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.role in ['student', 'provider']
        && (data.role == 'student' || (
          data.phone is string && 
          data.address is string && 
          data.latitude is number && 
          data.longitude is number
        ))
        && data.createdAt is number
        && data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']);
    }

    function isValidMeal(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.price is number && data.price >= 0
        && data.category in ['veg', 'non-veg']
        && data.imageUrl is string && data.imageUrl.size() > 0
        && data.providerId == request.auth.uid
        && data.providerName is string && data.providerName.size() > 0
        && data.createdAt is number
        && data.keys().hasAll(['title', 'price', 'category', 'imageUrl', 'providerId', 'providerName', 'createdAt'])
        && data.keys().size() == 7;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.userName is string && data.userName.size() > 0
        && data.mealId is string
        && data.mealTitle is string
        && data.mealPrice is number
        && data.mealImageUrl is string
        && data.providerId is string
        && data.status in ['pending', 'delivered']
        && data.timestamp is number
        && data.keys().hasAll(['userId', 'userName', 'mealId', 'mealTitle', 'mealPrice', 'mealImageUrl', 'providerId', 'status', 'timestamp'])
        && data.keys().size() == 9;
    }

    function isValidReview(data) {
      return data.userId == request.auth.uid
        && data.userName is string
        && data.mealId is string
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 500
        && data.timestamp is number
        && data.keys().hasAll(['userId', 'userName', 'mealId', 'rating', 'comment', 'timestamp'])
        && data.keys().size() == 6;
    }

    // Collection Rules
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow discovery of nearby providers
      allow create: if isSignedIn() && isValidUser(incoming()) && uid == request.auth.uid;
      allow update: if isSignedIn() && uid == request.auth.uid 
        && isValidUser(incoming())
        && incoming().role == existing().role
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'address', 'latitude', 'longitude', 'rating', 'reviewCount']);
    }

    match /meals/{mealId} {
      allow read: if true; // Public browsing
      allow create: if isSignedIn() && isEmailVerified() && getRole(request.auth.uid) == 'provider' && isValidMeal(incoming());
      allow delete: if isSignedIn() && existing().providerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || existing().providerId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.providerId == request.auth.uid);
      allow create: if isSignedIn() && getRole(request.auth.uid) == 'student' && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isSignedIn() && existing().providerId == request.auth.uid 
        && isValidOrder(incoming())
        && incoming().status == 'delivered'
        && existing().status == 'pending' // Only allow move to delivered once
        && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
    }
  }
}
